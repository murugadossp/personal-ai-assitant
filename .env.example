# =============================================================================
# Root .env.example — copy to `.env` files where each app expects them (never commit .env)
# =============================================================================

# --- personal-ai-assistant/ (copy to personal-ai-assistant/.env) ---
# GOOGLE_API_KEY=
# GOOGLE_GENAI_USE_VERTEXAI=False
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=
# ASSISTANT_TIMEZONE=UTC
# ENABLE_ADK_WEB_UI=false

# --- mcp-servers/google_workspace/ (copy to mcp-servers/google_workspace/.env) ---
# GCP_PROJECT=
# BASE_URL=https://your-workspace-mcp-xxxxx.run.app
# GOOGLE_OAUTH_CREDENTIALS=./credentials.json
# TOKEN_BACKEND=local
