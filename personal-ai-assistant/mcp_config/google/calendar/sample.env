# Google Calendar MCP — Environment Variables
# Copy this to .env or export these in your shell

# Required: Path to your OAuth credentials JSON
GOOGLE_OAUTH_CREDENTIALS=./mcp_config/google/calendar/gcp-oauth.keys.json

# Optional: Custom path for cached OAuth tokens
# GOOGLE_CALENDAR_MCP_TOKEN_PATH=~/.config/google-calendar-mcp/tokens.json
